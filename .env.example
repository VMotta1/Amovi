# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Plaid ─────────────────────────────────────────────────────────────────────
# Get these from: https://dashboard.plaid.com → Team Settings → Keys
# Use "sandbox" for local development (free, no real bank needed)
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_sandbox_secret_here
PLAID_ENV=sandbox

# ── Anthropic (AI backend) ────────────────────────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
# Only needed if running the FastAPI backend (backend/.env also needs this)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
